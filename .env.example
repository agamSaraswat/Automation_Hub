# Copy to .env and fill values for services you use.

# ── AI provider keys ───────────────────────────────────────────────────────────
# At least one provider key is required.  ANTHROPIC_API_KEY is the default.

ANTHROPIC_API_KEY=
GEMINI_API_KEY=AIzaSyDU1hf2zU_OSwNXcxdxJo2bOabvmf7HHaM
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=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

# ── Multi-provider routing ─────────────────────────────────────────────────────
# ACTIVE_PROVIDER selects the primary LLM backend.
# Supported values: anthropic | gemini | groq | openrouter   (default: anthropic)
ACTIVE_PROVIDER=anthropic

# FALLBACK_CHAIN is a comma-separated list of providers tried in order when
# the primary hits a rate limit or returns an error.
# Example: if ACTIVE_PROVIDER=gemini and FALLBACK_CHAIN=groq,openrouter,anthropic
# then on failure the client will try Groq, then OpenRouter, then Anthropic.
# If unset, the remaining providers are tried in the default order:
#   anthropic → gemini → groq → openrouter
FALLBACK_CHAIN=

# Task routing — pin specific harness phases to specific providers.
# Leave blank to use ACTIVE_PROVIDER for all phases.
PLANNER_PROVIDER=
GENERATOR_PROVIDER=
EVALUATOR_PROVIDER=

# ── LinkedIn ───────────────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:
LINKEDIN_TOKEN_SET_DATE=2026-01-01

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials.json

# ── App settings ──────────────────────────────────────────────────────────────
# Active user profile (matches a filename in config/profiles/, e.g. agam or soumyabrata)
ACTIVE_USER=agam

# Web API / local overrides
WEB_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TIMEZONE=America/New_York
DAILY_JOB_LIMIT=
